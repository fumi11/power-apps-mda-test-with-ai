# Power Apps Model-Driven App URL
MDA_URL=https://yourorg.crm.dynamics.com

# Entra ID (Azure AD) credentials
MDA_USERNAME=user@yourorg.onmicrosoft.com
MDA_PASSWORD=your-password

# Azure AD Tenant ID (for MSAL authentication)
TENANT_ID=your-tenant-id

# Azure AD Client ID (App Registration for Dataverse API access)
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret

# OpenAI API Key (for AI test generation)
OPENAI_API_KEY=sk-your-openai-api-key

# OpenAI Model (default: gpt-4o)
OPENAI_MODEL=gpt-4o
